{
  "name": "blindswarm",
  "version": "0.2.0",
  "description": "Privacy-preserving multi-agent AI orchestration protocol on Midnight Network",
  "main": "dist/src/index.js",
  "type": "module",
  "bin": {
    "gaming-studio": "./bin/blindswarm.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "echo \"No tests yet\"",
    "typecheck": "tsc --noEmit",
    "demo": "node dist/src/cli/index.js demo --run",
    "demo:tui": "node dist/src/cli/index.js demo --run --no-tui",
    "midnight:compile": "npx nightforge compile",
    "midnight:init": "npx nightforge init",
    "midnight:sync": "npx nightforge sync",
    "midnight:wallet": "npx nightforge wallet",
    "midnight:deploy": "npx nightforge deploy",
    "midnight:ps": "npx nightforge ps",
    "midnight:clean": "npx nightforge clean",
    "start-proof-server": "npx nightforge ps start",
    "start:server": "tsx src/server.ts",
    "link": "npm run build && npm link",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "midnight",
    "blockchain",
    "ai",
    "agents",
    "orchestration",
    "privacy"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@midnight-ntwrk/compact-runtime": "^0.15.0",
    "@midnight-ntwrk/midnight-js-contracts": "^4.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^4.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "^4.0.4",
    "@midnight-ntwrk/wallet-sdk-facade": "^3.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "^3.0.1",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.8.0",
    "@scure/bip39": "^1.6.0",
    "canonical-json": "^0.1.0",
    "classic-level": "^3.0.0",
    "commander": "^11.0.0",
    "dotenv": "^16.4.0",
    "ink": "^4.0.0",
    "nightforge": "^1.0.0",
    "openai": "^6.33.0",
    "react": "^18.2.0",
    "rxjs": "^7.8.0",
    "ws": "^8.19.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
