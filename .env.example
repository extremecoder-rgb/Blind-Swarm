# BlindSwarm Environment Configuration
# Copy this file to .env and fill in your values

# Gemini AI API Key (get from https://aistudio.google.com/app/apikey)
# Optional - demo will use mock AI if not set
GEMINI_API_KEY=

# Midnight Network Configuration
# Testnet: https://testnet.midnight.network
# Preprod: https://rpc.preprod.midnight.network
MIDNIGHT_PROVIDER_URL=https://testnet.midnight.network

# Wallet Configuration
# For real deployment, set your 64-character wallet seed
# Leave empty to use mock wallet in demo mode
MIDNIGHT_WALLET_SEED=

# Contract Address (after deployment)
MIDNIGHT_CONTRACT_ADDRESS=
